  graphql:
    expressionTypeName: SubscriberResourceOrderByExp

---
kind: Model
version: v2
definition:
  name: SubscriberResource
  objectType: SubscriberResource
  source:
    dataConnectorName: mailkite_pgsql
    collection: subscriber_resource
  filterExpressionType: SubscriberResourceBoolExp
  aggregateExpression: SubscriberResourceAggExp
  orderByExpression: SubscriberResourceOrderByExp
  graphql:
    selectMany:
      queryRootField: subscriberResource
      subscription:
        rootField: subscriberResource
    selectUniques:
      - queryRootField: subscriberResourceById
        uniqueIdentifier:
