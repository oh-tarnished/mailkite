---
kind: ObjectType
version: v1
definition:
  name: SubscriberResource
  fields:
    - name: attributes
      type: Json
    - name: createTime
      type: Timestamp!
    - name: displayName
      type: String_1!
    - name: email
      type: String_1!
    - name: id
      type: String_1!
    - name: name
      type: String_1!
    - name: state
      type: Enum
    - name: updateTime
      type: Timestamp!
    - name: uuid
      type: String_1
  graphql:
    typeName: SubscriberResource
    inputTypeName: SubscriberResourceInput
  dataConnectorTypeMapping:
    - dataConnectorName: mailkite_pgsql
      dataConnectorObjectType: subscriber_resource
      fieldMapping:
        attributes:
          column:
            name: attributes
        createTime:
          column:
            name: create_time
        displayName:
          column:
            name: display_name
        email:
          column:
            name: email
        id:
          column:
            name: id
        name:
          column:
            name: name
        state:
          column:
            name: state
        updateTime:
          column:
            name: update_time
        uuid:
          column:
            name: uuid

---
kind: TypePermissions
version: v1
definition:
  typeName: SubscriberResource
  permissions:
    - role: admin
      output:
        allowedFields:
          - attributes
          - createTime
          - displayName
          - email
          - id
          - name
          - state
          - updateTime
          - uuid

---
kind: BooleanExpressionType
version: v1
definition:
  name: SubscriberResourceBoolExp
  operand:
    object:
      type: SubscriberResource
      comparableFields:
        - fieldName: attributes
          booleanExpressionType: JsonbBoolExp
        - fieldName: createTime
          booleanExpressionType: TimestampBoolExp
        - fieldName: displayName
          booleanExpressionType: TextBoolExp
        - fieldName: email
          booleanExpressionType: TextBoolExp
        - fieldName: id
          booleanExpressionType: TextBoolExp
        - fieldName: name
          booleanExpressionType: TextBoolExp
        - fieldName: state
          booleanExpressionType: SubscriberSubscriberStateBoolExp
        - fieldName: updateTime
          booleanExpressionType: TimestampBoolExp
        - fieldName: uuid
          booleanExpressionType: TextBoolExp
      comparableRelationships:
        - relationshipName: bounceResources
        - relationshipName: subscriberSubscriptions
  logicalOperators:
    enable: true
  isNull:
    enable: true
  graphql:
    typeName: SubscriberResourceBoolExp

---
kind: AggregateExpression
version: v1
definition:
  name: SubscriberResourceAggExp
  operand:
    object:
      aggregatedType: SubscriberResource
      aggregatableFields:
        - fieldName: attributes
