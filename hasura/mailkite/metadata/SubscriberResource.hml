      subscription:
        rootField: subscriberResourceAggregate

---
kind: ModelPermissions
version: v1
definition:
  modelName: SubscriberResource
  permissions:
    - role: admin
      select:
        filter: null
        allowSubscriptions: true

---
kind: Relationship
version: v1
definition:
  name: bounceResources
  sourceType: SubscriberResource
  target:
