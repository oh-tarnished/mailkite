        - fieldName: state
          aggregateExpression: SubscriberSubscriberStateAggExp
        - fieldName: updateTime
          aggregateExpression: TimestampAggExp
        - fieldName: uuid
          aggregateExpression: TextAggExp
  count:
    enable: true
    returnType: Int64
  graphql:
    selectTypeName: SubscriberResourceAggExp

---
kind: OrderByExpression
version: v1
definition:
  name: SubscriberResourceOrderByExp
  operand:
    object:
